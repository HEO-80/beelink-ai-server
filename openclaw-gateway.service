[Unit]
Description=OpenClaw Gateway
After=network.target

[Service]
Type=simple
Environment="PATH=/home/heo/.nvm/versions/node/v22.22.0/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/heo/.nvm/versions/node/v22.22.0/bin/openclaw gateway run --bind loopback --port 18789 --force
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
